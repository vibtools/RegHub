APP_NAME=RegHub
APP_ENV=production
APP_DEBUG=false
PUBLIC_BASE_URL=https://reghub.ygit.dev
ALLOWED_HOSTS=["reghub.ygit.dev","localhost","127.0.0.1","testserver"]
CORS_ORIGINS=["https://ygit.net","https://www.ygit.net"]

DATABASE_URL=postgresql+asyncpg://reghub:change-me@postgres:5432/reghub
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

SESSION_SECRET=replace-with-at-least-32-random-characters
SESSION_COOKIE_SECURE=true
SESSION_MAX_AGE_SECONDS=28800

OIDC_ISSUER_URL=https://auth.vib.tools/realms/YOUR_REALM
OIDC_CLIENT_ID=reghub
OIDC_CLIENT_SECRET=
OIDC_SCOPES=openid profile email
OIDC_ADMIN_CLAIM=roles
OIDC_ADMIN_VALUES=["reghub-admin"]
OIDC_END_SESSION_URL=

# Company-managed fine-grained PAT. Runtime secret; build variable OFF.
GITHUB_TOKEN=
GITHUB_TIMEOUT_SECONDS=15
GITHUB_ALLOW_PRIVATE_REPOSITORIES=false

# Optional registry provider credentials. Public repositories work without them.
GITLAB_TOKEN=
BITBUCKET_USERNAME=
BITBUCKET_APP_PASSWORD=
PROVIDER_TIMEOUT_SECONDS=20

# Optional OpenAI-compatible metadata enrichment. Deterministic metadata works when disabled.
AI_METADATA_ENABLED=false
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=gpt-4.1-mini

# Optional isolated screenshot service. RegHub never runs template code itself.
SCREENSHOT_SERVICE_URL=
SCREENSHOT_SERVICE_TOKEN=

# Local manifest/ZIP imports are disabled by default.
LOCAL_UPLOAD_ENABLED=false
LOCAL_UPLOAD_MAX_BYTES=25000000
LOCAL_UPLOAD_MAX_UNCOMPRESSED_BYTES=100000000
LOCAL_UPLOAD_MAX_ENTRIES=2000

PUBLIC_API_CACHE_SECONDS=60
LOG_LEVEL=INFO
