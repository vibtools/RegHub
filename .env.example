APP_NAME=RegHub
APP_ENV=production
APP_DEBUG=false
PUBLIC_BASE_URL=https://reghub.ygit.dev
ALLOWED_HOSTS=["reghub.ygit.dev","localhost","127.0.0.1","testserver"]
CORS_ORIGINS=["http://localhost:3000","https://ygit.net","https://www.ygit.net"]

DATABASE_URL=postgresql+asyncpg://reghub:change-me@postgres:5432/reghub
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

SESSION_SECRET=replace-with-at-least-32-random-characters
SESSION_COOKIE_SECURE=true
SESSION_MAX_AGE_SECONDS=28800

OIDC_ISSUER_URL=https://auth.vib.tools
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPES=openid profile email
OIDC_ADMIN_CLAIM=roles
OIDC_ADMIN_VALUES=["reghub-admin"]
OIDC_END_SESSION_URL=

GITHUB_TOKEN=
GITHUB_TIMEOUT_SECONDS=15
GITHUB_ALLOW_PRIVATE_REPOSITORIES=false

PUBLIC_API_CACHE_SECONDS=60
LOG_LEVEL=INFO
