APP_NAME=RegHub
APP_ENV=development
APP_DEBUG=true
PUBLIC_BASE_URL=http://localhost:8000
ALLOWED_HOSTS=["localhost","127.0.0.1","testserver"]
CORS_ORIGINS=["http://localhost:3000"]
DATABASE_URL=postgresql+asyncpg://reghub:reghub-local-password@postgres:5432/reghub
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5
SESSION_SECRET=development-secret-change-this-value-123456789
SESSION_COOKIE_SECURE=false
OIDC_ISSUER_URL=https://auth.vib.tools/realms/YOUR_REALM
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_ADMIN_CLAIM=roles
OIDC_ADMIN_VALUES=["reghub-admin"]
GITHUB_TOKEN=
GITLAB_TOKEN=
BITBUCKET_USERNAME=
BITBUCKET_APP_PASSWORD=
AI_METADATA_ENABLED=false
LOCAL_UPLOAD_ENABLED=true
REDIS_URL=redis://redis:6379/0
OPERATION_BACKEND=redis
CACHE_BACKEND=redis
RATE_LIMIT_BACKEND=redis
TRUSTED_PROXY_NETWORKS=["127.0.0.1/32","172.16.0.0/12"]
RUNTIME_ENCRYPTION_KEY=local-runtime-encryption-key-change-this-value
AUDIT_SIGNING_KEY=local-audit-signing-key-change-this-value
AUDIT_SIGNING_PREVIOUS_KEYS=[]
OIDC_ROLE_CLAIM=roles
OIDC_ROLE_VALUES={"super_admin":["reghub-admin"],"security_admin":["reghub-security-admin"],"publisher":["reghub-publisher"],"editor":["reghub-editor"],"viewer":["reghub-viewer"]}
